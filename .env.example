# =========================
# App
# =========================
# Obrigatorio em producao. Use "production" no Render.
NODE_ENV=development

# Default seguro: worker. Para validar no plano Free do Render, use manual.
QUEUE_MODE=manual

# Default: 4000.
PORT=4000

# Obrigatorio. URL publica do painel React. Para mais de uma origem, separe por virgula.
CLIENT_ORIGIN=http://localhost:5173

# Obrigatorio no frontend. URL publica da API.
VITE_API_URL=http://localhost:4000

# =========================
# Supabase
# =========================
# Obrigatorio. Project URL do Supabase.
SUPABASE_URL=https://your-project.supabase.co

# Obrigatorio. Service role key do Supabase. Nao exponha no frontend.
SUPABASE_SERVICE_ROLE_KEY=replace-me

# =========================
# Auth
# =========================
# Obrigatorio. Use uma string aleatoria longa, com pelo menos 16 caracteres.
JWT_SECRET=replace-with-a-long-random-secret

# Usado somente ao rodar: npx tsx server/scripts/seed.ts
SEED_TENANT_NAME=ThM ConnectX
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=replace-with-a-secure-password

# =========================
# Redis
# =========================
# Obrigatorio apenas quando QUEUE_MODE=worker. No modo manual/free, pode manter o default local.
REDIS_URL=redis://localhost:6379

# =========================
# WhatsApp Cloud API
# =========================
# Obrigatorio para validar webhook da Meta.
WHATSAPP_VERIFY_TOKEN=replace-me

# Obrigatorio para enviar mensagens reais.
WHATSAPP_ACCESS_TOKEN=replace-me

# Obrigatorio para enviar mensagens e validar a Graph API.
WHATSAPP_PHONE_NUMBER_ID=replace-me

# Obrigatorio para listar/validar templates oficiais.
WHATSAPP_BUSINESS_ACCOUNT_ID=replace-me

# Obrigatorio em producao para validar assinatura do webhook Meta.
WHATSAPP_APP_SECRET=replace-me

# Default seguro atual. Ajuste se a Meta exigir outra versao.
WHATSAPP_API_VERSION=v20.0

# =========================
# OpenAI / Gemini
# =========================
# Valores aceitos: openai ou gemini.
AI_PROVIDER=gemini

# Obrigatorio se AI_PROVIDER=openai.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Obrigatorio se AI_PROVIDER=gemini.
GEMINI_API_KEY=replace-me
GEMINI_MODEL=gemini-3.5-flash

# =========================
# Google Places
# =========================
# Opcional. Necessario para a aba Prospeccao buscar empresas reais no Google.
GOOGLE_PLACES_API_KEY=
